# 이 파일을 복사한 .env 에 값을 채우면 자동으로 Supabase 를 쓴다. (값 없으면 JSON 파일 모드)
# 배포(Render 등) 시엔 .env 대신 호스팅의 "환경변수"에 같은 키들을 넣는다.
#
# ── Supabase (supabase-js) — 권장 ────────────────────────────────────────
# 대시보드 → Project Settings → API:
#   Project URL              → SUPABASE_URL
#   service_role (secret) 키 → SUPABASE_SERVICE_ROLE_KEY
#   ⚠️ anon 아님! service_role(비밀) 키. 백엔드 전용 — 프론트/공개 금지.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 관리자 비밀번호 — 설정하면 관리/세팅 화면에 로그인 필요(보드는 공개). 비우면 인증 없음.
MANAGER_PASSWORD=

# ── 대안: Postgres 직접연결 (위 Supabase 를 쓰면 비워둠) ──────────────────
# DATABASE_URL=postgresql://postgres:[비밀번호]@db.[REF].supabase.co:5432/postgres
# PGSSL=disable   # 로컬 무SSL 테스트용만

# 선택 — 기본 배정 8분(480) / 휴게 10분(600)
# ASSIGN_DELAY_SEC=480
# BREAK_DELAY_SEC=600
# PORT=3000
